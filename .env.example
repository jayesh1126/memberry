# MEMBERRY configuration — copy to .env and pick ONE profile below.
# Cognee needs an LLM *and* an embedding model. Profiles wire up both.
# Note: single backslashes are invalid in .env values — use / or \\ in paths.

# ============================================================
# PROFILE A — OpenAI (simplest: one key does LLM + embeddings)
# ============================================================
# LLM_API_KEY="sk-your-openai-key"
#   Defaults: openai/gpt-5-mini (LLM) + openai/text-embedding-3-large (embeddings)

# ============================================================
# PROFILE B — OpenRouter LLM + local fastembed embeddings
#   Only needs your OpenRouter key. Embeddings run locally (free, no GPU).
#   Install extra:  pip install "cognee[fastembed]"
# ============================================================
# LLM_PROVIDER="openai"
# LLM_MODEL="openrouter/anthropic/claude-3.5-sonnet"
# LLM_ENDPOINT="https://openrouter.ai/api/v1"
# LLM_API_KEY="sk-or-your-openrouter-key"
#
# EMBEDDING_PROVIDER="fastembed"
# EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
# EMBEDDING_DIMENSIONS="384"

# ============================================================
# PROFILE C — Fully local with Ollama (no API key, no cloud)
#   Install extra:  pip install "cognee[ollama]"
#   ollama pull llama3.1:8b && ollama pull nomic-embed-text:latest
# ============================================================
# LLM_PROVIDER="ollama"
# LLM_MODEL="llama3.1:8b"
# LLM_ENDPOINT="http://localhost:11434/v1"
# LLM_API_KEY="ollama"
#
# EMBEDDING_PROVIDER="ollama"
# EMBEDDING_MODEL="nomic-embed-text:latest"
# EMBEDDING_ENDPOINT="http://localhost:11434/api/embed"
# EMBEDDING_DIMENSIONS="768"
# HUGGINGFACE_TOKENIZER="nomic-ai/nomic-embed-text-v1.5"

# ============================================================
# MEMBERRY behaviour (provider-independent)
# ============================================================
MEMBERRY_DATASET=memberry
MEMBERRY_MAX_FILE_KB=256
MEMBERRY_HOST=127.0.0.1
MEMBERRY_PORT=8765

# Optional storage locations (default under ~/.memberry).
# Use forward slashes on Windows.
# MEMBERRY_DATA_DIR="C:/Users/jayes/.memberry/data"
# MEMBERRY_SYSTEM_DIR="C:/Users/jayes/.memberry/system"
